generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Vercel's Neon integration sets these automatically:
  // - POSTGRES_PRISMA_URL: pooled connection for runtime queries
  // - POSTGRES_URL_NON_POOLING: direct connection for migrations
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt DateTime?
  plan        UserPlan    @default(free)
  isPro       Boolean     @default(false)
  proValidUntil DateTime?

  accounts      Account[]
  sessions      Session[]
  stripeCustomer StripeCustomer?
  stripeSubscription StripeSubscription?
  premiumUsages PremiumUsage[]
}

/// Pro会員向けプレミアムAIの月間使用回数。カレンダー月（YYYY-MM）ごとにリセット。
model PremiumUsage {
  id        String   @id @default(cuid())
  userId    String
  yearMonth String   // "2025-02"
  usedCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, yearMonth])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model StripeCustomer {
  id               String     @id @default(cuid())
  userId           String     @unique
  stripeCustomerId String     @unique
  stripeMode       StripeMode
  createdAt        DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum StripeMode {
  test
  live
}

enum UserPlan {
  free
  pro
}

model StripeSubscription {
  id                   String     @id @default(cuid())
  userId               String     @unique
  stripeSubscriptionId String     @unique
  stripeCustomerId     String
  stripeProductId      String?
  stripePriceId        String?
  status               String
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean    @default(false)
  canceledAt           DateTime?
  endedAt              DateTime?
  trialEnd             DateTime?
  latestInvoiceId      String?
  latestInvoiceStatus  String?
  stripeMode           StripeMode
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId, stripeMode])
}

model StripeWebhookEvent {
  id         String     @id @default(cuid())
  eventId    String
  type       String
  stripeMode StripeMode
  receivedAt DateTime   @default(now())

  @@unique([eventId, stripeMode])
  @@index([stripeMode, receivedAt])
}

model PendingCheckout {
  id                     String    @id @default(cuid())
  // Email is stored encrypted to minimize PII exposure in DB.
  // This record is short-lived and is deleted/ignored after expiry/consumption.
  emailEnc               String
  // Normalized email hash (peppered) for lightweight lookups without storing plaintext.
  emailHash              String
  tokenHash              String    @unique
  stripeCheckoutSessionId String?  @unique
  stripeMode             StripeMode
  expiresAt              DateTime
  completedAt            DateTime?
  usedAt                 DateTime?
  createdAt              DateTime  @default(now())
 
  @@index([emailHash, stripeMode, createdAt])
  @@index([stripeMode, createdAt])
}
